generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model Device {
  id       String @id @default(uuid())
  siteId   String
  lat      Float
  lon      Float

  weatherLogs  Weather[]   
  parkingLogs  Parking[]   
  restroomLogs Restroom[]  
}

model Weather {
  id            String   @id @default(uuid())
  deviceId      String
  temperature   Float
  humidity      Float
  pm25          Float
  rain          Float?
  windSpeed     Float?
  windDirection Float?
  timestamp     DateTime

  device Device @relation(fields: [deviceId], references: [id])
}

model Parking {
  id        String   @id @default(uuid())
  deviceId  String
  capacity  Int      
  available Int?     
  timestamp DateTime

  device Device @relation(fields: [deviceId], references: [id])
}

model Restroom {
  id              String   @id @default(uuid())
  deviceId        String
  maleStalls      Int      
  maleAvailable   Int      
  femaleStalls    Int      
  femaleAvailable Int      
  timestamp       DateTime

  device Device @relation(fields: [deviceId], references: [id])
}