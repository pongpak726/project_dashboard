generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  loginLogs LoginLog[]
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model Device {
  id       String  @id // ✅ "siteName:deviceId"
  siteName String
  lat      Decimal @db.Decimal(11, 8)
  lon      Decimal @db.Decimal(11, 8)

  weatherLogs  Weather[]
  parkingLogs  Parking[]
  restroomLogs Restroom[]

  @@index([siteName])
}

model Weather {
  id            String   @id @default(uuid())
  deviceId      String
  temperature   Float
  humidity      Float
  pm25          Float
  rain          Float?
  windSpeed     Float?
  windDirection Float?
  timestamp     DateTime

  device Device @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, timestamp])
  @@index([timestamp])
}

model Parking {
  id        String   @id @default(uuid())
  deviceId  String
  capacity  Int
  available Int?
  timestamp DateTime

  device Device @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, timestamp])
  @@index([timestamp])
}

model Restroom {
  id              String   @id @default(uuid())
  deviceId        String
  maleStalls      Int
  maleAvailable   Int
  femaleStalls    Int
  femaleAvailable Int
  timestamp       DateTime

  device Device @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, timestamp])
  @@index([timestamp])
}

model VMS {
  id       String @id // เช่น "bangkok_01:vms-001"
  siteName String
  lat      Float?
  lon      Float?

  currentImage String? // URL ภาพล่าสุด
  updatedAt    DateTime @updatedAt

  logs VMSLog[]

  @@index([siteName])
}

model VMSLog {
  id        String   @id @default(uuid())
  vmsId     String
  imageUrl  String
  timestamp DateTime

  vms VMS @relation(fields: [vmsId], references: [id])

  @@unique([vmsId, timestamp])
  @@index([timestamp])
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String
  username  String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}
